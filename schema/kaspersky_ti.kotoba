// Kaspersky_ti clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace kaspersky_ti {

    entity Indicator {
        id: string @unique
        type: string
        value: string
        confidence: integer
        firstSeen: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Vulnerability {
        id: string @unique
        cveId: string
        cvss: float
        description: string
        published: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity ThreatActor {
        id: string @unique
        name: string
        motivation: string
        sophistication: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Campaign {
        id: string @unique
        name: string
        actorId: string
        firstSeen: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Host {
        id: string @unique
        ipAddress: string
        asn: string
        country: string
        openPorts: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Technique {
        id: string @unique
        attckId: string
        tactic: string
        name: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
